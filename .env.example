# Backend
APP_NAME=StarWhisper
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-this-in-production

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ML
MODEL_PATH=/app/backend/app/ml/artifacts/xgboost_model.joblib
FEATURE_NAMES_PATH=/app/backend/app/ml/artifacts/feature_names.joblib
SCALER_PATH=/app/backend/app/ml/artifacts/scaler.joblib

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# File upload
MAX_UPLOAD_SIZE=104857600

# Catalog for validation (optional)
CATALOG_PATH=/data/catalog.csv
